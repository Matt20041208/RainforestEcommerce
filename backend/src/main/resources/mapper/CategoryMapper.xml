<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yulin.ecommerce.product.mapper.CategoryMapper">
    
    <resultMap id="BaseResultMap" type="com.yulin.ecommerce.product.entity.Category">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="enabled" property="enabled"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>
    
    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM t_category WHERE id = #{id}
    </select>
    
    <select id="findByEnabled" resultMap="BaseResultMap">
        SELECT * FROM t_category
        <where>
            <if test="enabled != null">
                enabled = #{enabled}
            </if>
        </where>
        ORDER BY sort_order ASC
    </select>
    
    <select id="existsByName" resultType="boolean">
        SELECT COUNT(1) > 0 FROM t_category WHERE name = #{name}
    </select>
    
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_category (name, description, sort_order, enabled, create_time, update_time)
        VALUES (#{name}, #{description}, #{sortOrder}, #{enabled}, NOW(), NOW())
    </insert>
    
    <update id="updateById">
        UPDATE t_category SET 
            name = #{name},
            description = #{description},
            sort_order = #{sortOrder},
            enabled = #{enabled},
            update_time = NOW()
        WHERE id = #{id}
    </update>
    
    <delete id="deleteById">
        DELETE FROM t_category WHERE id = #{id}
    </delete>
</mapper>
